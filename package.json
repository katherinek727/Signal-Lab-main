{
  "name": "signal-lab",
  "version": "0.1.0",
  "private": true,
  "description": "Signal Lab — observability playground with AI layer",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "lint": "eslint \"apps/**/*.{ts,tsx}\" --max-warnings 0",
    "format": "prettier --write \"apps/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
