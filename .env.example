# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal
POSTGRES_DB=signal_lab
DATABASE_URL=postgresql://signal:signal@postgres:5432/signal_lab

# ─── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=3001

# ─── Sentry ──────────────────────────────────────────────────────────────────
# Replace with your actual DSN from https://sentry.io
SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# ─── Observability ───────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3100
LOKI_PORT=3200

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
